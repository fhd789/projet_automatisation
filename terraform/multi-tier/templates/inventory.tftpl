---
all:
  children:
    webservers:
      hosts:
        novasphere-web:
          ansible_host: ${web_ip}
          ansible_user: ${ssh_user}
          ansible_ssh_private_key_file: ${ssh_key}
          ansible_ssh_common_args: '-o ProxyCommand="ssh -W %h:%p -i ${ssh_key} ${ssh_user}@${bastion_ip}"'